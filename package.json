{
  "name": "vekha",
  "version": "1.0.0",
  "description": "Веха — конструктор занятий для педагогов",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win --x64",
    "build:linux": "electron-builder --linux --x64",
    "build:all": "electron-builder --win --linux --x64"
  },
  "dependencies": {
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "ru.vekha.app",
    "productName": "Веха",
    "copyright": "© 2025 Веха",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "report_template.js",
      "src/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "src/assets/logo.jpg"
    },
    "linux": {
      "target": [{ "target": "AppImage", "arch": ["x64"] }],
      "icon": "src/assets/logo.jpg",
      "category": "Education"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Веха"
    }
  }
}
