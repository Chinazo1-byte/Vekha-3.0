{
  "name": "vekha",
  "version": "1.0.0",
  "description": "Веха — конструктор занятий для педагогов",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev":   "electron . --dev",
    "build": "electron-builder --win --x64",
    "build:dir": "electron-builder --win --x64 --dir"
  },
  "dependencies": {
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "ru.vekha.app",
    "productName": "Веха",
    "copyright": "© 2025 Веха",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "report_template.js",
      "src/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "src/assets/logo.jpg"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": ["ru"],
      "language": "1049",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Веха"
    }
  }
}
