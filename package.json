{
  "name": "vekha",
  "version": "1.0.5",
  "description": "Веха — конструктор занятий для педагогов",
  "author": "Chinazo1-byte",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win --x64 --publish never",
    "build:linux": "electron-builder --linux --x64 --publish never",
    "build:all": "electron-builder --win --linux --x64 --publish never",
    "release": "electron-builder --publish always",
    "release:win": "electron-builder --win --x64 --publish always",
    "release:linux": "electron-builder --linux --x64 --publish always",
    "patch": "node scripts/bump.js patch",
    "minor": "node scripts/bump.js minor",
    "major": "node scripts/bump.js major"
  },
  "dependencies": {
    "sql.js": "^1.12.0",
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "ru.vekha.app",
    "productName": "Веха",
    "copyright": "© 2025 Веха",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "report_template.js",
      "src/**/*",
      "node_modules/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "Chinazo1-byte",
      "repo": "Vekha-3.0"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/assets/logo.jpg",
      "artifactName": "vekha-setup-${version}.exe"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/assets/logo.png",
      "category": "Education",
      "artifactName": "vekha-${version}.AppImage"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Веха"
    }
  }
}
